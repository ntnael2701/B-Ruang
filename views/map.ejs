<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Peta Ruangan - B-Ruang</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
  </head>
  <body>
    <div class="container">
      <header class="page-header">
        <div>
          <h1>Peta Ruangan</h1>
          <p>Lihat ruangan yang kosong atau sudah dibooking hari ini.</p>
        </div>
        <div class="header-actions">
          <span>Halo, <strong><%= user.name %></strong></span>
          <a href="/student" class="btn btn-secondary">Kembali</a>
          <a href="/logout" class="btn btn-secondary">Logout</a>
        </div>
      </header>

      <section class="card">
        <div id="map" class="map-container"></div>
      </section>

      <section class="card booking-sheet">
        <div class="sheet-header">
          <div>
            <h2>Spreadsheet Booking Ruangan</h2>
            <p>Informasi ruangan yang sudah dibooking dan waktu booking hari ini.</p>
          </div>
          <div class="sheet-summary">
            <span><strong><%= rooms.filter(r => r.bookings.length > 0).length %></strong> ruangan terbooking</span>
            <span><strong><%= rooms.length %></strong> total ruangan</span>
          </div>
        </div>
        <div class="table-wrap">
          <table class="booking-table">
            <thead>
              <tr>
                <th>Ruang</th>
                <th>Area</th>
                <th>Waktu Terbooking</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% rooms.forEach(room => { %>
                <tr>
                  <td><strong><%= room.name %></strong></td>
                  <td><%= room.area %></td>
                  <td>
                    <% if (room.bookings && room.bookings.length > 0) { %>
                      <% room.bookings.forEach(booking => { %>
                        <div style="font-size: 0.9em; margin: 4px 0;">
                          <%= booking.start_time %> - <%= booking.end_time %>
                        </div>
                      <% }); %>
                    <% } else { %>
                      <span style="color: #999;">-</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (room.bookings && room.bookings.length > 0) { %>
                      <span class="status rejected">Terbooking</span>
                    <% } else { %>
                      <span class="status approved">Tersedia</span>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script>
      // initialize map
      var center = <%= JSON.stringify(center) %>;
      var rooms = <%= JSON.stringify(rooms) %>;

      var map = L.map('map').setView(center, 17);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);

      rooms.forEach(function(room) {
        var isBooked = room.bookings && room.bookings.length > 0;
        var marker = L.circleMarker(room.coords, {
          radius: 10,
          color: isBooked ? '#d8472f' : '#2f6f46',
          fillColor: isBooked ? '#f8d7d5' : '#dff3e6',
          fillOpacity: 0.9
        }).addTo(map);
        
        // Build popup content with booking times
        var popupContent = '<strong>' + room.name + '</strong><br>' + room.area + '<br>';
        
        if (isBooked && room.bookings.length > 0) {
          popupContent += '<br><strong style="color: #d8472f;">Jam Terbooking:</strong><ul style="margin: 5px 0; padding-left: 20px; font-size: 0.9em;">';
          room.bookings.forEach(function(booking) {
            popupContent += '<li>' + booking.start_time + ' - ' + booking.end_time + '</li>';
          });
          popupContent += '</ul>';
        } else {
          popupContent += '<strong style="color: #2f6f46;">Status: Tersedia</strong>';
        }
        
        marker.bindPopup(popupContent);
      });
    </script>
  </body>
</html>
