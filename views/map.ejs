<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Peta Ruangan - B-Ruang</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
  </head>
  <body>
    <div class="container">
      <header class="page-header">
        <div>
          <h1>Peta Ruangan</h1>
          <p>Lihat ruangan yang kosong atau sudah dibooking pada tanggal tertentu.</p>
        </div>
        <div class="header-actions">
          <span>Halo, <strong><%= user.name %></strong></span>
          <a href="/student" class="btn btn-secondary">Kembali</a>
          <a href="/logout" class="btn btn-secondary">Logout</a>
        </div>
      </header>

      <section class="card">
        <div style="display:flex; gap:12px; align-items:center; margin-bottom:8px;">
          <label for="datePicker">Pilih tanggal:</label>
          <input type="date" id="datePicker" value="<%= today %>" />
          <small style="color:#666;">(Tampilkan jadwal booking untuk tanggal terpilih)</small>
        </div>
        <div id="map" class="map-container"></div>
        <div style="display:flex; gap:12px; margin: 10px 0; align-items:center;">
          <div style="display:flex; align-items:center; gap:8px;">
            <span style="width:12px; height:12px; border-radius:50%; background:#d8472f; display:inline-block;"></span>
            <span>Terbooking</span>
          </div>
          <div style="display:flex; align-items:center; gap:8px;">
            <span style="width:12px; height:12px; border-radius:50%; background:#2f6f46; display:inline-block;"></span>
            <span>Tersedia</span>
          </div>
        </div>
        <div style="margin-top:12px;">
          <div id="roomsGrid" class="rooms-grid">
            <% rooms.forEach(room => { %>
              <div class="room-card" style="border: 1px solid rgba(0,0,0,0.04);">
                <h3><%= room.name %></h3>
                <p><strong><%= room.area %></strong> — kapasitas <%= room.capacity %> orang</p>
                <% if (room.bookings && room.bookings.length > 0) { %>
                  <div class="status rejected">Terbooking hari ini</div>
                  <div style="margin-top: 10px; background: #fff8f0; padding: 10px; border-radius: 8px; font-size: 12px;">
                    <strong style="color: #d8472f;">Jam yang tidak tersedia:</strong>
                    <ul style="margin: 5px 0; padding-left: 18px;">
                      <% room.bookings.forEach(booking => { %>
                        <li>
                          <strong><%= booking.start_time %></strong> - <strong><%= booking.end_time %></strong>
                          <br><span style="color: #666;">(Peminjam: <%= booking.user_name %>)</span>
                        </li>
                      <% }); %>
                    </ul>
                  </div>
                <% } else { %>
                  <div class="status approved">Tersedia sepanjang hari</div>
                <% } %>
              </div>
            <% }); %>
          </div>
        </div>
      </section>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script>
      // initialize map
      var center = <%= JSON.stringify(center) %>;
      var rooms = <%= JSON.stringify(rooms) %>;
      var map = L.map('map').setView(center, 17);
      var currentMarkers = [];

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);

      function buildPopup(room) {
        var popupContent = '<strong>' + room.name + '</strong><br>' + room.area + '<br>';
        if (room.bookings && room.bookings.length > 0) {
          popupContent += '<div style="margin-top: 8px; padding: 8px; background: #fff8f0; border-radius: 4px;">';
          popupContent += '<strong style="color: #d8472f;">Jadwal booking:</strong><br>';
          room.bookings.forEach(function(booking) {
            popupContent += booking.start_time + ' - ' + booking.end_time + '<br>';
          });
          popupContent += '</div>';
        } else {
          popupContent += '<strong style="color: #2f6f46;">Status: Tersedia</strong>';
        }
        return popupContent;
      }

      function renderMarkers(roomsData) {
        currentMarkers.forEach(function(marker) {
          map.removeLayer(marker);
        });
        currentMarkers = [];

        roomsData.forEach(function(room) {
          var isBooked = room.bookings && room.bookings.length > 0;
          var marker = L.circleMarker(room.coords, {
            radius: 10,
            color: isBooked ? '#d8472f' : '#2f6f46',
            fillColor: isBooked ? '#f8d7d5' : '#dff3e6',
            fillOpacity: 0.9
          }).addTo(map);
          marker.bindPopup(buildPopup(room));
          currentMarkers.push(marker);
        });
      }

      function renderRoomsGrid(roomsData) {
        var grid = document.getElementById('roomsGrid');
        var html = '';
        roomsData.forEach(function(room) {
          var isBooked = room.bookings && room.bookings.length > 0;
          html += '<div class="room-card" style="border: 1px solid rgba(0,0,0,0.04);">';
          html += '<h3>' + room.name + '</h3>';
          html += '<p><strong>' + room.area + '</strong> — kapasitas ' + room.capacity + ' orang</p>';
          if (isBooked) {
            html += '<div class="status rejected">Terbooking hari ini</div>';
            html += '<div style="margin-top: 10px; background: #fff8f0; padding: 10px; border-radius: 8px; font-size: 12px;">';
            html += '<strong style="color: #d8472f;">Jam yang tidak tersedia:</strong>';
            html += '<ul style="margin: 5px 0; padding-left: 18px;">';
            room.bookings.forEach(function(booking) {
              html += '<li><strong>' + booking.start_time + '</strong> - <strong>' + booking.end_time + '</strong>';
              html += '<br><span style="color: #666;">(Peminjam: ' + booking.user_name + ')</span></li>';
            });
            html += '</ul></div>';
          } else {
            html += '<div class="status approved">Tersedia sepanjang hari</div>';
          }
          html += '</div>';
        });
        grid.innerHTML = html;
      }

      function fetchBookings(date) {
        fetch('/api/bookings?date=' + encodeURIComponent(date), { credentials: 'same-origin' })
          .then(function(response) {
            if (!response.ok) throw new Error('Gagal memuat jadwal');
            return response.json();
          })
          .then(function(data) {
            renderMarkers(data.rooms);
            renderRoomsGrid(data.rooms);
          })
          .catch(function(error) {
            console.error(error);
            alert('Tidak dapat memuat jadwal booking untuk tanggal ini.');
          });
      }

      document.getElementById('datePicker').addEventListener('change', function(event) {
        if (event.target.value) {
          fetchBookings(event.target.value);
        }
      });

      // Load booking data for the selected date on initial page load
      fetchBookings(document.getElementById('datePicker').value);
    </script>
  </body>
</html>
