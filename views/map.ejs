<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Peta Ruangan - B-Ruang</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="container">
      <header class="page-header">
        <div>
          <h1>Peta Ruangan</h1>
          <p>Lihat ruangan yang kosong atau sudah dibooking.</p>
        </div>
        <div class="header-actions">
          <span>Halo, <strong><%= user.name %></strong></span>
          <a href="/student" class="btn btn-secondary">Kembali</a>
          <a href="/logout" class="btn btn-secondary">Logout</a>
        </div>
      </header>

      <section class="card" style="margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 15px; padding: 15px; background-color: rgba(95, 61, 196, 0.05); border-radius: 12px;">
          <label for="dateFilter" style="font-weight: 600; white-space: nowrap;">Pilih Tanggal:</label>
          <input type="date" id="dateFilter" value="<%= selectedDate %>" style="padding: 8px 12px; border: 1px solid rgba(95, 61, 196, 0.18); border-radius: 8px; font-size: 1em;">
          <span id="dateInfo" style="color: #666; font-size: 0.95em;"></span>
        </div>
      </section>

      <section class="card">
        <div id="map" class="map-container"></div>
      </section>

      <section class="card booking-sheet">
        <div class="sheet-header">
          <div>
            <h2>Spreadsheet Booking Ruangan</h2>
            <p>Informasi ruangan yang sudah dibooking dan waktu booking hari ini.</p>
          </div>
          <div class="sheet-summary">
            <span><strong><%= rooms.filter(r => r.bookings.length > 0).length %></strong> ruangan terbooking</span>
            <span><strong><%= rooms.length %></strong> total ruangan</span>
          </div>
        </div>
        <div class="table-wrap">
          <table class="booking-table">
            <thead>
              <tr>
                <th>Ruang</th>
                <th>Area</th>
                <th>Waktu Terbooking</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% rooms.forEach(room => { %>
                <% if (room.bookings && room.bookings.length > 0) { %>
                  <% room.bookings.forEach((booking, index) => { %>
                    <tr class="booking-row">
                      <td><%= index === 0 ? room.name : '' %></td>
                      <td><%= index === 0 ? room.area : '' %></td>
                      <td><%= booking.start_time %> - <%= booking.end_time %></td>
                      <td class="status rejected">Booked</td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr class="available-row">
                    <td><%= room.name %></td>
                    <td><%= room.area %></td>
                    <td colspan="2">Tersedia sepanjang hari</td>
                  </tr>
                <% } %>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>
    </div>

    <% if (googleMapsApiKey) { %>
      <script src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&callback=initMap" async defer></script>
    <% } %>
    <script>
      const selectedDateInput = document.getElementById('dateFilter');
      const dateInfo = document.getElementById('dateInfo');
      const mapContainer = document.getElementById('map');
      const googleMapsApiKey = <%- JSON.stringify(googleMapsApiKey) %>;
      const center = <%= JSON.stringify(center) %>;
      const rooms = <%= JSON.stringify(rooms) %>;
      const interactiveButtons = document.querySelectorAll('.btn, .btn-secondary, .btn-approve, .btn-reject');

      function formatDate(dateStr) {
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        return new Date(dateStr + 'T00:00:00').toLocaleDateString('id-ID', options);
      }

      function updateDateInfo() {
        dateInfo.textContent = '(' + formatDate(selectedDateInput.value) + ')';
      }

      function animateButtonClick(event) {
        const button = event.currentTarget;
        button.classList.add('btn-clicked');
        setTimeout(() => button.classList.remove('btn-clicked'), 320);
      }

      interactiveButtons.forEach(button => {
        button.addEventListener('click', animateButtonClick);
      });

      updateDateInfo();

      selectedDateInput.addEventListener('change', function() {
        updateDateInfo();
        window.location.href = '/map?date=' + this.value;
      });

      function createRoomPopup(room) {
        let content = '<div style="font-family: Arial, sans-serif; line-height: 1.4; max-width: 260px;">';
        content += '<strong>' + room.name + '</strong><br>' + room.area + '<br>';
        if (room.bookings && room.bookings.length > 0) {
          content += '<br><strong style="color: #d8472f;">Jam Terbooking:</strong><ul style="margin: 6px 0 0; padding-left: 16px; font-size: 0.92em;">';
          room.bookings.forEach(booking => {
            content += '<li>' + booking.start_time + ' - ' + booking.end_time + '</li>';
          });
          content += '</ul>';
        } else {
          content += '<strong style="color: #2f6f46;">Status: Tersedia</strong>';
        }
        content += '</div>';
        return content;
      }

      function renderFallbackMap() {
        mapContainer.innerHTML = '<iframe class="map-iframe" src="https://www.google.com/maps?q=Universitas+Diponegoro+Semarang&z=17&output=embed" allowfullscreen loading="lazy"></iframe>';
      }

      function initMap() {
        if (!googleMapsApiKey) {
          renderFallbackMap();
          return;
        }

        const map = new google.maps.Map(mapContainer, {
          center: { lat: center[0], lng: center[1] },
          zoom: 17,
          mapTypeId: 'roadmap'
        });

        rooms.forEach(room => {
          const isBooked = room.bookings && room.bookings.length > 0;
          const marker = new google.maps.Marker({
            position: { lat: room.coords[0], lng: room.coords[1] },
            map,
            title: room.name,
            icon: {
              path: google.maps.SymbolPath.CIRCLE,
              scale: 9,
              fillColor: isBooked ? '#d8472f' : '#2f6f46',
              fillOpacity: 0.9,
              strokeColor: isBooked ? '#9f2f1a' : '#1f4f2d',
              strokeWeight: 2
            }
          });

          const infoWindow = new google.maps.InfoWindow({
            content: createRoomPopup(room)
          });

          marker.addListener('click', () => infoWindow.open(map, marker));
        });
      }

      if (googleMapsApiKey) {
        window.initMap = initMap;
      } else {
        renderFallbackMap();
      }
    </script>
  </body>
</html>
