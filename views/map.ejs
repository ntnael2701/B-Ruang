<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Peta Ruangan - B-Ruang</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />
  </head>
  <body>
    <div class="container">
      <header class="page-header">
        <div>
          <h1>Peta Ruangan</h1>
          <p>Lihat ruangan yang kosong atau sudah dibooking.</p>
        </div>
        <div class="header-actions">
          <span>Halo, <strong><%= user.name %></strong></span>
          <a href="/student" class="btn btn-secondary">Kembali</a>
          <a href="/logout" class="btn btn-secondary">Logout</a>
        </div>
      </header>

      <section class="card" style="margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 15px; padding: 15px; background-color: rgba(95, 61, 196, 0.05); border-radius: 12px;">
          <label for="dateFilter" style="font-weight: 600; white-space: nowrap;">Pilih Tanggal:</label>
          <input type="date" id="dateFilter" value="<%= selectedDate %>" style="padding: 8px 12px; border: 1px solid rgba(95, 61, 196, 0.18); border-radius: 8px; font-size: 1em;">
          <span id="dateInfo" style="color: #666; font-size: 0.95em;"></span>
        </div>
      </section>

      <section class="card">
        <div id="map" class="map-container"></div>
        <div style="margin-top:12px;">
          <div class="rooms-grid">
            <% rooms.forEach(room => { %>
              <div class="room-card" style="border: 1px solid rgba(0,0,0,0.04);">
                <h3><%= room.name %></h3>
                <p><strong><%= room.area %></strong> — kapasitas <%= room.capacity %> orang</p>
                <% if (room.bookings && room.bookings.length > 0) { %>
                  <div class="status rejected">Terbooking</div>
                  <div style="margin-top: 10px; padding: 8px; background-color: rgba(216, 71, 47, 0.1); border-radius: 6px; font-size: 0.9em;">
                    <strong>Jam yang Terbooking:</strong>
                    <ul style="margin: 5px 0; padding-left: 20px;">
                      <% room.bookings.forEach(booking => { %>
                        <li><%= booking.start_time %> - <%= booking.end_time %></li>
                      <% }); %>
                    </ul>
                  </div>
                <% } else { %>
                  <div class="status approved">Tersedia</div>
                <% } %>
              </div>
            <% }); %>
          </div>
        </div>
      </section>
    </div>
    <script src="/vendor/leaflet/leaflet.js"></script>
    <script>
      // Format tanggal untuk display
      const selectedDateInput = document.getElementById('dateFilter');
      const dateInfo = document.getElementById('dateInfo');
      
      function formatDate(dateStr) {
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        return new Date(dateStr + 'T00:00:00').toLocaleDateString('id-ID', options);
      }
      
      function updateDateInfo() {
        dateInfo.textContent = '(' + formatDate(selectedDateInput.value) + ')';
      }
      
      updateDateInfo();
      
      selectedDateInput.addEventListener('change', function() {
        updateDateInfo();
        // Reload peta dengan tanggal baru
        window.location.href = '/map?date=' + this.value;
      });
      
      // initialize map
      var center = <%= JSON.stringify(center) %>;
      var rooms = <%= JSON.stringify(rooms) %>;

      // Helpers to compute free ranges
      function parseTimeToMinutes(t) {
        if (!t) return null;
        const [h, m] = t.split(':').map(Number);
        return h * 60 + m;
      }

      function minutesToTime(m) {
        const hh = String(Math.floor(m / 60)).padStart(2, '0');
        const mm = String(m % 60).padStart(2, '0');
        return hh + ':' + mm;
      }

      // bookings: [{start_time, end_time}, ...]
      function computeFreeRanges(bookings, dayStart = '07:00', dayEnd = '22:00') {
        const startMin = parseTimeToMinutes(dayStart);
        const endMin = parseTimeToMinutes(dayEnd);
        if (!bookings || bookings.length === 0) return [{ start: minutesToTime(startMin), end: minutesToTime(endMin) }];

        // Convert and sort
        const intervals = bookings.map(b => ({
          s: parseTimeToMinutes(b.start_time),
          e: parseTimeToMinutes(b.end_time)
        })).sort((a, b) => a.s - b.s);

        // Merge overlapping intervals
        const merged = [];
        intervals.forEach(iv => {
          if (iv.e <= iv.s) return; // skip invalid
          if (!merged.length || iv.s > merged[merged.length - 1].e) merged.push({ ...iv });
          else merged[merged.length - 1].e = Math.max(merged[merged.length - 1].e, iv.e);
        });

        const free = [];
        // before first
        if (merged[0].s > startMin) free.push({ start: minutesToTime(startMin), end: minutesToTime(merged[0].s) });
        // between
        for (let i = 0; i < merged.length - 1; i++) {
          if (merged[i].e < merged[i + 1].s) free.push({ start: minutesToTime(merged[i].e), end: minutesToTime(merged[i + 1].s) });
        }
        // after last
        if (merged[merged.length - 1].e < endMin) free.push({ start: minutesToTime(merged[merged.length - 1].e), end: minutesToTime(endMin) });

        return free;
      }

      var map = L.map('map').setView(center, 17);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);

      rooms.forEach(function(room) {
        var isBooked = room.bookings && room.bookings.length > 0;
        var marker = L.circleMarker(room.coords, {
          radius: 10,
          color: isBooked ? '#d8472f' : '#2f6f46',
          fillColor: isBooked ? '#f8d7d5' : '#dff3e6',
          fillOpacity: 0.9
        }).addTo(map);
        
        // Compute available ranges (default operational hours 07:00-22:00)
        const freeRanges = computeFreeRanges(room.bookings, '07:00', '22:00');

        // Build popup content with booking times and available slots
        var popupContent = '<strong>' + room.name + '</strong><br>' + room.area + '<br>';
        
        if (isBooked && room.bookings.length > 0) {
          popupContent += '<br><strong style="color: #d8472f;">Jam Terbooking:</strong><ul style="margin: 5px 0; padding-left: 20px; font-size: 0.9em;">';
          room.bookings.forEach(function(booking) {
            popupContent += '<li>' + booking.start_time + ' - ' + booking.end_time + '</li>';
          });
          popupContent += '</ul>';
        } else {
          popupContent += '<strong style="color: #2f6f46;">Status: Tersedia</strong>';
        }

        if (freeRanges && freeRanges.length > 0) {
          popupContent += '<br><strong style="color: #2f6f46;">Jam Tersedia:</strong><ul style="margin: 5px 0; padding-left: 20px; font-size: 0.9em;">';
          freeRanges.forEach(function(slot) {
            popupContent += '<li>' + slot.start + ' - ' + slot.end + '</li>';
          });
          popupContent += '</ul>';
        }

        // Build a short tooltip summary
        var tooltipSummary = '';
        if (!isBooked) {
          tooltipSummary = 'Kosong: 07:00 - 22:00';
        } else {
          var bookedSummary = room.bookings.map(b => b.start_time + '–' + b.end_time).join('; ');
          var freeSummary = freeRanges.map(s => s.start + '–' + s.end).join('; ');
          tooltipSummary = 'Terbooking: ' + bookedSummary + (freeSummary ? ' | Tersedia: ' + freeSummary : '');
        }

        marker.bindTooltip(tooltipSummary, { direction: 'top', offset: [0, -10] });
        marker.bindPopup(popupContent);
      });
    </script>
  </body>
</html>
