<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Peta Ruangan - B-Ruang</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-sA+e2k9Qb2FQYx3YkGkGynm4bM6Qw1p2Gf9s6z6bMqo=" crossorigin="" />
  </head>
  <body>
    <div class="container">
      <header class="page-header">
        <div>
          <h1>Peta Ruangan</h1>
          <p>Lihat ruangan yang kosong atau sudah dibooking hari ini.</p>
        </div>
        <div class="header-actions">
          <span>Halo, <strong><%= user.name %></strong></span>
          <a href="/student" class="btn btn-secondary">Kembali</a>
          <a href="/logout" class="btn btn-secondary">Logout</a>
        </div>
      </header>

      <section class="card">
        <div id="map" class="map-container"></div>
        <div style="margin-top:12px;">
          <div class="rooms-grid">
            <% rooms.forEach(room => { %>
              <div class="room-card" style="border: 1px solid rgba(0,0,0,0.04);">
                <h3><%= room.name %></h3>
                <p><strong><%= room.area %></strong> — kapasitas <%= room.capacity %> orang</p>
                <% if (room.booked_today && room.booked_today > 0) { %>
                  <div class="status rejected">Terbooking hari ini</div>
                <% } else { %>
                  <div class="status approved">Tersedia</div>
                <% } %>
              </div>
            <% }); %>
          </div>
        </div>
      </section>
    </div>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha256-o9N1j7f4b0b8r5f5b6k6s0n0p3y2l1r4qvQ0p6+4n8M=" crossorigin=""></script>
    <script>
      // initialize map
      var center = <%= JSON.stringify(center) %>;
      var rooms = <%= JSON.stringify(rooms) %>;

      var map = L.map('map').setView(center, 17);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);

      rooms.forEach(function(room) {
        var isBooked = room.booked_today && room.booked_today > 0;
        var marker = L.circleMarker(room.coords, {
          radius: 10,
          color: isBooked ? '#d8472f' : '#2f6f46',
          fillColor: isBooked ? '#f8d7d5' : '#dff3e6',
          fillOpacity: 0.9
        }).addTo(map);
        marker.bindPopup('<strong>' + room.name + '</strong><br>' + room.area + '<br>Status: ' + (isBooked ? 'Terbooking' : 'Tersedia'));
      });
    </script>
  </body>
</html>
