<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>B-Ruang Mahasiswa</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="container">
      <header class="page-header">
        <div>
          <h1>B-Ruang</h1>
          <p>Booking ruangan Undip untuk acara.</p>
        </div>
        <div class="header-actions">
          <span>Halo, <strong><%= user.name %></strong></span>
          <a href="/map" class="btn btn-secondary">Peta Ruangan</a>
          <a href="/download-template" class="btn btn-secondary">Download Template Surat</a>
          <a href="/logout" class="btn btn-secondary">Logout</a>
        </div>
      </header>

      <section class="card">
        <h2>Ruang tersedia</h2>
        <div class="rooms-grid">
          <% rooms.forEach(room => { %>
            <div class="room-card">
              <h3><%= room.name %></h3>
              <p>Luas: <strong><%= room.area %></strong></p>
              <p>Kapasitas: <strong><%= room.capacity %> orang</strong></p>
            </div>
          <% }); %>
        </div>
      </section>

      <section class="card booking-card">
        <h2>Permintaan Booking</h2>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert"><%= error %></div>
        <% } %>
        <form action="/book" method="post" enctype="multipart/form-data" class="booking-form">
          <label>Ruang</label>
          <select name="room_id" required>
            <% rooms.forEach(room => { %>
              <option value="<%= room.id %>"><%= room.name %> - <%= room.area %>, kapasitas <%= room.capacity %></option>
            <% }); %>
          </select>
          <label>Tanggal</label>
          <input type="date" name="date" required />
          <label>Jam mulai</label>
          <input type="time" name="start_time" required />
          <label>Jam selesai</label>
          <input type="time" name="end_time" required />
          <label>Keperluan acara</label>
          <textarea name="purpose" rows="3" required placeholder="Contoh: Seminar, diskusi organisasi..."></textarea>
          <label>Unggah surat permohonan (.doc, .docx, .pdf)</label>
          <input type="file" name="letter_pdf" accept=".doc,.docx,.pdf" required />
          <button type="submit" class="btn">Kirim Permintaan</button>
        </form>
      </section>

      <section class="card">
        <h2>Inbox Notifikasi</h2>
        <% if (!notifications || notifications.length === 0) { %>
          <p class="hint">Belum ada notifikasi.</p>
        <% } else { %>
          <div class="notification-list">
            <% notifications.forEach(note => { %>
              <div class="notification-item <%= note.status.toLowerCase() %>">
                <p><%= note.message %></p>
                <div class="notification-meta">
                  <span><%= note.created_at %></span>
                  <span class="note-status"><%= note.status %></span>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </section>

      <section class="card">
        <h2>Status Booking Saya</h2>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Ruang</th>
                <th>Tanggal</th>
                <th>Jam</th>
                <th>Keperluan</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (bookings.length === 0) { %>
                <tr><td colspan="5" class="empty">Belum ada permintaan booking.</td></tr>
              <% } %>
              <% bookings.forEach(booking => { %>
                <tr>
                  <td><%= booking.room_name %></td>
                  <td><%= booking.date %></td>
                  <td><%= booking.start_time %> - <%= booking.end_time %></td>
                  <td><%= booking.purpose %></td>
                  <td class="status <%= booking.status.toLowerCase() %>"><%= booking.status %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </body>
</html>
